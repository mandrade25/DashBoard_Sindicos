# Banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/minimerx_db?schema=public"

# NextAuth.js v5
# Gerar com: openssl rand -base64 32
AUTH_SECRET="troque-este-valor-em-producao"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Produção
# NEXTAUTH_URL="https://dashboard.minimerx.com.br"
NODE_ENV="development"

# Upload de arquivos
UPLOADS_DIR=./uploads

# SMTP (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=dashboard@minimerx.com.br
SMTP_PASS=senha_aqui
SMTP_FROM="MiniMerX <dashboard@minimerx.com.br>"
